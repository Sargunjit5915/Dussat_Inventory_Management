# .env.local
# Copy this file, rename to .env.local, and fill in your values.
# NEVER commit .env.local to version control.

# ── Firebase config ───────────────────────────────────────
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# ── Admin registration key ────────────────────────────────
# Anyone who enters this key during registration gets role="admin".
# Use a long, random string. Change it after your first admin is created.
VITE_ADMIN_SECRET_KEY=change-this-to-a-strong-secret
