// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────

    // Is the request from an authenticated user?
    function isAuthed() {
      return request.auth != null;
    }

    // Is the requesting user an admin?
    function isAdmin() {
      return isAuthed() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Is the requesting user the owner of a document?
    function isOwner(ownerId) {
      return isAuthed() && request.auth.uid == ownerId;
    }

    // ── users collection ──────────────────────────────────
    match /users/{userId} {
      // Users can read/write their own profile. Admins can read all profiles.
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);    // created at registration
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── inventory collection ──────────────────────────────
    match /inventory/{itemId} {
      // Any authenticated user can read and create inventory items.
      allow read:   if isAuthed();
      allow create: if isAuthed();
      // Only the user who added the item, or an Admin, can update/delete.
      allow update: if isAuthed() && (
                      isOwner(resource.data.addedBy) || isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // ── orderRequests collection ──────────────────────────
    match /orderRequests/{requestId} {
      // Users can create requests and read their own. Admins can read all.
      allow create: if isAuthed();
      allow read:   if isAuthed() && (
                      isOwner(resource.data.requestedBy) || isAdmin()
                    );
      // Only Admins can update order status (approve/reject/order).
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

  }
}
