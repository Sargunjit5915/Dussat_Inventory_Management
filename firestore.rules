// firestore.rules — v3 fixed
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(ownerId) {
      return isAuthed() && request.auth.uid == ownerId;
    }

    // ── users ─────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── inventory ─────────────────────────────────────────
    match /inventory/{itemId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed() && (isOwner(resource.data.addedBy) || isAdmin());
      allow delete: if isAdmin();
    }

    // ── orderRequests ─────────────────────────────────────
    match /orderRequests/{requestId} {
      // Any authed user can create a new order/draft
      allow create: if isAuthed();

      // Owner can read their own docs; admins can read all
      allow read: if isAuthed() && (isOwner(resource.data.requestedBy) || isAdmin());

      // Owner can update their OWN draft (save draft, submit draft)
      // Admin can update any order (approve/reject/review)
      allow update: if isAuthed() && (
                      isOwner(resource.data.requestedBy) || isAdmin()
                    );

      // Owner can delete their own DRAFT; admin can delete anything
      allow delete: if isAuthed() && (
                      isOwner(resource.data.requestedBy) || isAdmin()
                    );
    }

  }
}
